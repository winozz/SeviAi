    "/feedback": {
      "post": {
        "tags": [
          "Feedback"
        ],
        "summary": "Submit Feedback",
        "description": "Submit user feedback for a specific bot response.\n\nBody fields:\n    message_id (int, optional): ID of the chat_messages row being rated\n    rating (int, optional): Quality score 1–5\n    helpful (bool, optional): True = thumbs up, False = thumbs down\n    comment (str, optional): Freeform note or correction\n    suggested_intent (str, optional): User-supplied intent correction\n    user_id / session_id (str, optional): For cross-referencing\n    intent (str, optional): Intent tag of the rated response",
        "operationId": "submit_feedback_feedback_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
